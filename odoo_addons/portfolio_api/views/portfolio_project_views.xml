<odoo>
    <record id="portfolio_project_tree_view" model="ir.ui.view">
        <field name="name">portfolio.project.tree</field>
        <field name="model">portfolio.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="tags"/>
                <field name="demo_url"/>
                <field name="github_url"/>
                <field name="is_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="portfolio_project_form_view" model="ir.ui.view">
        <field name="name">portfolio.project.form</field>
        <field name="model">portfolio.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="is_published"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image_url"/>
                            <field name="demo_url"/>
                            <field name="github_url"/>
                        </group>
                    </group>
                    <group>
                        <field name="tags"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="portfolio_project_search_view" model="ir.ui.view">
        <field name="name">portfolio.project.search</field>
        <field name="model">portfolio.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tags"/>
                <filter name="published" string="Published" domain="[('is_published', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="portfolio_project_action" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">portfolio.project</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="portfolio_project_search_view"/>
    </record>
</odoo>
