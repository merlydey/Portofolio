<odoo>
    <record id="portfolio_contact_tree_view" model="ir.ui.view">
        <field name="name">portfolio.contact.tree</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="source"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="portfolio_contact_form_view" model="ir.ui.view">
        <field name="name">portfolio.contact.form</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="source"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="ip_address" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="user_agent" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="portfolio_contact_search_view" model="ir.ui.view">
        <field name="name">portfolio.contact.search</field>
        <field name="model">portfolio.contact</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="email"/>
                <field name="source"/>
                <filter name="new" string="New" domain="[('state', '=', 'new')]"/>
                <filter name="reviewed" string="Reviewed" domain="[('state', '=', 'reviewed')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
            </search>
        </field>
    </record>

    <record id="portfolio_contact_action" model="ir.actions.act_window">
        <field name="name">Contacts</field>
        <field name="res_model">portfolio.contact</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="portfolio_contact_search_view"/>
    </record>
</odoo>
